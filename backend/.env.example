# Copy this file to .env and adjust values for your environment

# Application
VELLAM_APP_NAME=Vellam
VELLAM_APP_VERSION=0.1.0
VELLAM_DEBUG=true
VELLAM_HOST=127.0.0.1
VELLAM_PORT=8000

# Ollama (must be running locally)
VELLAM_OLLAMA_BASE_URL=http://localhost:11434
VELLAM_OLLAMA_DEFAULT_MODEL=llama3.2
VELLAM_OLLAMA_TIMEOUT=120

# xAI / Grok
VELLAM_XAI_BASE_URL=https://api.x.ai/v1

# Database (SQLite by default)
VELLAM_DATABASE_URL=sqlite+aiosqlite:///./vellam.db

# CORS - allowed origins for the frontend
VELLAM_CORS_ORIGINS=["http://localhost:3000","http://localhost:3500","http://localhost:5173"]

# Logging
VELLAM_LOG_LEVEL=INFO
VELLAM_LOG_FILE=logs/app.log

# Browser
VELLAM_BROWSER_HEADLESS=false

# File uploads
VELLAM_UPLOAD_DIR=uploads
VELLAM_MAX_UPLOAD_SIZE_MB=20
